{
  "name": "kidneybuddy-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec node --import tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node --import tsx --test src/test/*.test.ts",
    "db:generate": "drizzle-kit generate",
