    "userId": "11111111-1111-4111-8111-111111111111",
    "isi": "Alhamdulillah, ikut senang dengar kabar baiknya Pak Budi. Semoga terus sehat dan lancar ke depannya.",
    "createdAt": "2026-04-10T04:00:00.000Z"
  },
