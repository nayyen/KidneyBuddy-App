# Copy this to .env and fill in values before running docker compose.
# Generate new secrets anytime with:
#   node -e "const c=require('crypto'); console.log(c.randomBytes(32).toString('hex'))"
#   cd backend && node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k.publicKey); console.log(k.privateKey);"

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kidneybuddy:change-me@db:5432/kidneybuddy
POSTGRES_USER=kidneybuddy
POSTGRES_PASSWORD=change-me
POSTGRES_DB=kidneybuddy

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:4000
# Used by backend/src/services/email.service.ts to build the reset-password link.
FRONTEND_URL=http://localhost:3000

# ─── Encryption (AES-256-GCM, 32-byte = 64 hex chars) ───────────────────────
# NEVER commit the real value.
ENCRYPTION_KEY=<64-hex-chars>

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=<random-hex>
JWT_REFRESH_SECRET=<random-hex>

# ─── Web Push / VAPID ────────────────────────────────────────────────────────
# Generate ONCE and store safely — regenerating breaks existing push subscriptions.
VAPID_SUBJECT=mailto:your@email.com
VAPID_PUBLIC_KEY=<vapid-public-key>
VAPID_PRIVATE_KEY=<vapid-private-key>

# Frontend browser access (same value as VAPID_PUBLIC_KEY)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<same-as-VAPID_PUBLIC_KEY>

# ─── Groq (AI narration, Phase 5) ────────────────────────────────────────────
# Get one from https://console.groq.com/keys — NEVER commit the real value.
GROQ_API_KEY=<groq-api-key>

# ─── Resend (password-reset email) ──────────────────────────────────────────
# Get one from https://resend.com/api-keys — NEVER commit the real value.
# If unset, forgot-password falls back to console-logging the reset link (dev-safe).
RESEND_API_KEY=<resend-api-key>
RESEND_FROM_EMAIL=KidneyBuddy <no-reply@yourdomain.com>
