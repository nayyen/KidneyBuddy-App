# Database
DATABASE_URL=postgresql://kidneybuddy:kidneybuddy@db:5432/kidneybuddy
POSTGRES_USER=kidneybuddy
POSTGRES_PASSWORD=kidneybuddy
POSTGRES_DB=kidneybuddy

# Backend
NODE_ENV=development
JWT_ACCESS_SECRET=your-access-secret-change-in-prod
JWT_REFRESH_SECRET=your-refresh-secret-change-in-prod

# Frontend (browser-facing — must point to backend's publicly accessible URL)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── Encryption (NFR-02: AES-256-GCM app-layer encryption for health data) ───
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Result: 64 hex characters (32 bytes / 256 bits). NEVER commit the real key.
ENCRYPTION_KEY=replace-with-64-hex-chars-generated-by-the-command-above

# ─── VAPID Push Notifications (NOTIF-02, REMIND-08) ─────────────────────────
# Generate keypair ONCE (store safely, never regenerate — existing subscriptions break):
#   npx web-push generate-vapid-keys
# Copy the output into the four vars below.
# Apple APNs requires VAPID_SUBJECT to be "mailto:" or "https://" URL.
VAPID_SUBJECT=mailto:naykim426@gmail.com
VAPID_PUBLIC_KEY=replace-with-output-of-npx-web-push-generate-vapid-keys-public
VAPID_PRIVATE_KEY=replace-with-output-of-npx-web-push-generate-vapid-keys-private

# Frontend: same public key, exposed to browser for pushManager.subscribe()
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-same-value-as-VAPID_PUBLIC_KEY
